{
  "name": "games-collection",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env.local -- sh -c \"NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000\"",
    "build": "vite build && cp instrument.server.mjs .output/server",
    "preview": "vite preview",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
    "lint": "eslint",
    "format": "prettier",
    "check": "prettier --write . && eslint --fix"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "@neondatabase/serverless": "^1.0.2",
    "@sentry/tanstackstart-react": "^10.43.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/query-db-collection": "^1.0.29",
    "@tanstack/react-db": "^0.1.76",
    "@tanstack/react-devtools": "^0.9.13",
    "@tanstack/react-form": "^1.28.4",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.166.7",
    "@tanstack/react-router-devtools": "^1.166.7",
    "@tanstack/react-router-ssr-query": "^1.166.7",
    "@tanstack/react-start": "^1.166.8",
    "@tanstack/react-store": "^0.9.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.166.7",
    "@tanstack/store": "^0.9.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.577.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "vite-plugin-neon-new": "^0.8.0",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@netlify/vite-plugin-tanstack-start": "^1.2.20",
    "@tanstack/devtools-event-client": "^0.4.3",
    "@tanstack/devtools-vite": "^0.5.5",
    "@tanstack/eslint-config": "^0.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.4.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv": "^17.3.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "web-vitals": "^5.1.0"
  }
}